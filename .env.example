# Runtime
TASKS_ENV=development
TASKS_ENABLE_DOCS=true

# Database
TASKS_DATABASE_URL=postgresql+asyncpg://cycle_todo:changeme@localhost:5434/cycle_todo

# JWT / session
TASKS_JWT_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND_HEX_32
TASKS_JWT_ALGORITHM=HS256
TASKS_JWT_EXPIRE_DAYS=7
TASKS_COOKIE_SECURE=false
TASKS_COOKIE_DOMAIN=

# Test user (seeded on startup if both set)
TASKS_TEST_USER_EMAIL=
TASKS_TEST_USER_PASSWORD=

# Google OAuth (leave blank until Google Cloud Console is configured)
TASKS_GOOGLE_CLIENT_ID=
TASKS_GOOGLE_CLIENT_SECRET=
TASKS_GOOGLE_REDIRECT_URI=

# CORS (comma-separated)
TASKS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8000
